('Pirólise'),
('Laboratório Química');


create index idx_usuario_email
on usuarios(email);

create index idx_chamado_status
on chamados(status_chamado);

create index idx_chamado_prioridade
on chamados(prioridade);

create index idx_chamado_usuario
on chamados(usuario_id);

create index idx_chamado_tecnico
on chamados(tecnico_id);

show tables;

describe usuarios;
